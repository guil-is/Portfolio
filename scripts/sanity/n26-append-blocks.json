  },
  {
    "_key": "70308b3d3c8f",
    "children": [
      {
        "_type": "span",
        "marks": [],
        "text": "\"Metal was here before us, and will be here after us. It’s an authentic, raw element of what makes up our world",
        "_key": "70308b3d3c8f0"
      },
      {
        "_type": "span",
        "marks": [
          "em"
        ],
        "text": ". It also exists beyond our world. Metal is denser, more valuable and longer lasting. Weight is wealth.\"",
        "_key": "70308b3d3c8f1"
      }
    ],
    "markDefs": [],
    "_type": "block",
    "style": "blockquote"
  },
  {
    "_key": "efb8a092487f",
    "children": [
      {
        "_type": "span",
        "marks": [],
        "text": "Made in collaboration with ",
        "_key": "efb8a092487f0"
      },
      {
        "_type": "span",
        "marks": [
          "33757b7f5b15"
        ],
        "text": "Tim Doldissen",
        "_key": "efb8a092487f1"
      },
      {
        "_type": "span",
        "marks": [],
        "text": " and ",
        "_key": "efb8a092487f2"
      },
      {
        "_type": "span",
        "marks": [
